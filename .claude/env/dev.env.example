# LightCI Server — Development Environment Variables (EXAMPLE)
# =============================================================
# This file contains EXAMPLE values only. Never commit real credentials.
#
# USAGE:
#   cp .claude/env/dev.env.example .env
#   # Edit .env with your actual values
#   source .env
#
# The .env file is gitignored. Only this *.env.example file is committed.
#
# NAMING CONVENTION:
#   TF_VAR_xxx  — Passed automatically to Terraform as variable "xxx"
#   AWS_xxx     — Used by AWS CLI and Terraform AWS provider
#   DOCKER_xxx  — Used by Docker commands and DeploymentAgent
#   EC2_xxx     — Used by DeploymentAgent and post-deploy hook

# ─── AWS Configuration ────────────────────────────────────────────────────────

# AWS region where EC2 will be provisioned
AWS_REGION=us-east-1

# AWS CLI named profile (from ~/.aws/credentials)
# Use "default" unless you have multiple AWS accounts configured
AWS_PROFILE=default

# ─── Docker / Container Registry ─────────────────────────────────────────────

# Docker Hub username (the part before /image-name)
DOCKER_USERNAME=myusername

# Docker image name (repository name on Docker Hub)
DOCKER_IMAGE=light-ci-server

# Docker image tag — use 'dev' for development, semver for releases
DOCKER_TAG=dev

# Docker Hub access token (NOT your login password)
# Create at: https://hub.docker.com/settings/security
# In dev you may want to use your password for convenience, but use a token in CI
DOCKER_PASSWORD=dckr_pat_example_token_replace_this

# ─── EC2 Instance Configuration ───────────────────────────────────────────────

# Name of the AWS EC2 key pair (must already exist in your AWS account)
# Check existing key pairs: aws ec2 describe-key-pairs --region us-east-1
EC2_KEY_PAIR_NAME=lightci-dev-key

# EC2 instance type
# t3.micro is free tier eligible (750 hrs/month for 12 months)
EC2_INSTANCE_TYPE=t3.micro

# Public IP of the EC2 instance — set this AFTER running terraform apply
# Get it with: terraform output -raw instance_public_ip
EC2_PUBLIC_IP=54.123.45.67

# ─── SSH Configuration ────────────────────────────────────────────────────────

# Path to your .pem private key file for SSH access to EC2
# Keep this file with chmod 400 and NEVER commit it
SSH_KEY_PATH=~/keys/lightci-dev-key.pem

# ─── Application Configuration ────────────────────────────────────────────────

# Port the Spring Boot application listens on
APP_PORT=8080

# Docker container name on the EC2 host
CONTAINER_NAME=light-ci-server

# ─── Terraform Variables ──────────────────────────────────────────────────────
# TF_VAR_ prefix causes Terraform to use these as input variables automatically.
# These mirror the variables declared in terraform/variables.tf

TF_VAR_region=us-east-1
TF_VAR_aws_profile=default
TF_VAR_instance_type=t3.micro
TF_VAR_key_pair_name=lightci-dev-key
TF_VAR_app_port=8080
TF_VAR_environment=dev

# ─── Spring Boot Profiles ─────────────────────────────────────────────────────

# Active Spring profile for local development
SPRING_PROFILES_ACTIVE=dev

# ─── Logging ──────────────────────────────────────────────────────────────────

# Where to store generated Claude plans and audit logs locally
CLAUDE_LOG_DIR=.claude/logs

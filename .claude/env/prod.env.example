# LightCI Server — Production Environment Variables (EXAMPLE)
# ============================================================
# WARNING: This file is for PRODUCTION deployment.
# Production values have higher stakes — a misconfiguration can cause
# downtime or unexpected AWS charges.
#
# SECURITY RULES FOR PRODUCTION:
#   1. NEVER commit this file with real values.
#   2. Use AWS Secrets Manager or Parameter Store for sensitive values.
#   3. Use IAM roles instead of access keys where possible.
#   4. Restrict SSH CIDR to a VPN or bastion host IP, not 0.0.0.0/0.
#   5. Use a specific Docker tag (not 'latest') for reproducible deployments.
#   6. Use a t3.small or larger for production workloads.
#
# USAGE:
#   cp .claude/env/prod.env.example .env.prod
#   # Edit .env.prod with your actual PRODUCTION values
#   source .env.prod
#
# The .env.prod file is gitignored. Only this *.env.example file is committed.

# ─── AWS Configuration ────────────────────────────────────────────────────────

# Production AWS region
# WARNING: Changing this after first apply requires recreating all resources.
AWS_REGION=us-east-1

# Production AWS CLI profile — should be a dedicated production profile
# with minimal IAM permissions (principle of least privilege)
AWS_PROFILE=lightci-prod

# ─── Docker / Container Registry ─────────────────────────────────────────────

# Docker Hub username
DOCKER_USERNAME=mycompany

# Docker image name — consider a separate prod image name
DOCKER_IMAGE=light-ci-server

# IMPORTANT: Always pin to a specific release tag in production.
# Never use 'latest' in production — it makes rollback impossible.
DOCKER_TAG=1.0.0

# Docker Hub access token with read-only scope for production pulls
# Create a dedicated token with minimal scope:
# https://hub.docker.com/settings/security
DOCKER_PASSWORD=dckr_pat_production_token_replace_this

# ─── EC2 Instance Configuration ───────────────────────────────────────────────

# Production key pair name — separate key from dev
# NEVER share dev and prod SSH keys.
EC2_KEY_PAIR_NAME=lightci-prod-key

# Production instance type — t3.small minimum recommended for Spring Boot
# t3.micro (1 GB RAM) may trigger OOMKill under load
EC2_INSTANCE_TYPE=t3.small

# Production public IP — set after terraform apply
# PRODUCTION NOTE: For stable DNS, use an Elastic IP (aws_eip resource)
EC2_PUBLIC_IP=54.200.100.50

# ─── SSH Configuration ────────────────────────────────────────────────────────

# Production SSH key path
# SECURITY: Keep separate from dev key. Use chmod 400.
SSH_KEY_PATH=~/keys/lightci-prod-key.pem

# ─── Application Configuration ────────────────────────────────────────────────

# Production port
APP_PORT=8080

# Production container name
CONTAINER_NAME=light-ci-server-prod

# ─── Terraform Variables ──────────────────────────────────────────────────────

TF_VAR_region=us-east-1
TF_VAR_aws_profile=lightci-prod
TF_VAR_instance_type=t3.small
TF_VAR_key_pair_name=lightci-prod-key
TF_VAR_app_port=8080

# IMPORTANT: Must be "prod" so Terraform tags resources correctly
TF_VAR_environment=prod

# ─── Spring Boot Profiles ─────────────────────────────────────────────────────

# Production profile activates prod-specific application.properties settings
SPRING_PROFILES_ACTIVE=prod

# ─── Production-Specific Warnings ────────────────────────────────────────────
#
# Before running terraform apply with these values, verify:
#
# [  ] Terraform plan has been reviewed (terraform plan)
# [  ] Security group restricts SSH to your IP or VPN, not 0.0.0.0/0
# [  ] Docker image tag is a specific release version, not 'latest'
# [  ] EC2 key pair exists in the target AWS region
# [  ] Terraform state is stored in S3 backend (not local file)
# [  ] AWS CloudTrail is enabled in the target account
# [  ] EBS encryption is enabled (encrypted = true in main.tf)
# [  ] Pre-commit hook is installed: cp .claude/hooks/pre-commit.sh .git/hooks/pre-commit
# [  ] Security audit has been run: use /security-audit in Claude
#
# COST ESTIMATE (us-east-1, on-demand pricing as of 2026):
#   t3.small (24x7)   ~$15/month
#   EBS 20 GB gp3     ~$1.60/month
#   Data transfer     ~$0.09/GB outbound after 1 GB free
#   TOTAL             ~$17/month

# ─── AWS Secrets Manager Integration (Recommended for Production) ─────────────
#
# Instead of storing sensitive values here, use AWS Secrets Manager:
#
# Store:
#   aws secretsmanager create-secret \
#     --name "lightci/prod/docker-password" \
#     --secret-string "your-real-password" \
#     --region us-east-1
#
# Retrieve at deploy time:
#   export DOCKER_PASSWORD=$(aws secretsmanager get-secret-value \
#     --secret-id "lightci/prod/docker-password" \
#     --query SecretString --output text)
